<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ area.name }} &mdash; Literature Digest</title>
  <style>
    :root {
      --bg: #f8fafc; --surface: #ffffff; --fg: #0f172a; --muted: #64748b;
      --border: #e2e8f0; --accent: #2563eb; --accent-soft: #eff6ff;
      --strong: #15803d; --strong-soft: #dcfce7;
      --moderate: #b45309; --moderate-soft: #fef3c7;
      --low: #475569; --low-soft: #f1f5f9;
      --borderline: #be123c; --borderline-soft: #ffe4e6;
      --actionable: var(--strong); --monitoring: var(--moderate); --background: var(--low);
      --radius: 0.625rem; --shadow: 0 1px 2px rgba(15,23,42,.04), 0 1px 3px rgba(15,23,42,.06);
      --maxw: 60rem;
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      background: var(--bg); color: var(--fg); margin: 0; line-height: 1.55;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--accent); }
    a:hover { text-decoration: underline; }

    .layout { max-width: var(--maxw); margin: 0 auto; padding: 1.5rem 1.5rem 4rem; }

    /* Header */
    .back { font-size: .8rem; color: var(--muted); text-decoration: none; }
    h1 { margin: .35rem 0 .15rem; font-size: 1.6rem; letter-spacing: -0.01em; }
    .meta { color: var(--muted); font-size: .85rem; margin-bottom: 1rem; }
    .summary { display: flex; flex-wrap: wrap; gap: .5rem; margin: .75rem 0 0; }
    .summary span { background: var(--surface); border: 1px solid var(--border);
      border-radius: 999px; padding: .2rem .7rem; font-size: .75rem; color: var(--muted); }
    .summary b { color: var(--fg); font-variant-numeric: tabular-nums; }

    /* Filter bar */
    .filters { display: flex; flex-wrap: wrap; gap: .45rem; margin: 1.25rem 0 1.5rem;
      padding-bottom: .9rem; border-bottom: 1px solid var(--border); }
    .filter-btn { font: inherit; font-size: .82rem; color: var(--fg); background: var(--surface);
      border: 1px solid var(--border); border-radius: 999px; padding: .3rem .8rem;
      cursor: pointer; transition: background .12s, color .12s, border-color .12s;
      display: inline-flex; align-items: center; gap: .35rem; }
    .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
    .filter-btn[aria-pressed="true"] { background: var(--fg); color: #fff; border-color: var(--fg); }
    .filter-btn[aria-pressed="true"] .count { color: rgba(255,255,255,.8); }
    .filter-btn .count { color: var(--muted); font-variant-numeric: tabular-nums; font-size: .75rem; }

    .empty-filter { display: none; color: var(--muted); font-style: italic; padding: 1.5rem 0; }
    .empty-filter.is-visible { display: block; }

    /* Card */
    article.card { background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 1rem 1.15rem 1.1rem; margin-bottom: 1rem;
      box-shadow: var(--shadow); border-left: 4px solid var(--border); }
    article.card[hidden] { display: none; }
    article.card.band-strong { border-left-color: var(--strong); }
    article.card.band-moderate { border-left-color: var(--moderate); }
    article.card.band-low { border-left-color: var(--low); }
    article.card.is-borderline { border-left-color: var(--borderline);
      box-shadow: 0 0 0 1px var(--borderline-soft), var(--shadow); }

    .card-top { display: flex; justify-content: space-between; gap: .75rem; flex-wrap: wrap; }
    .badges { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }

    .score { font-weight: 700; font-variant-numeric: tabular-nums; font-size: .8rem;
      padding: .15rem .5rem; border-radius: .35rem; color: #fff; }
    .score.band-strong { background: var(--strong); }
    .score.band-moderate { background: var(--moderate); }
    .score.band-low { background: var(--low); }

    .chip { font-size: .72rem; font-weight: 600; padding: .15rem .55rem; border-radius: 999px;
      border: 1px solid transparent; white-space: nowrap; }
    .chip.directly-actionable { background: var(--strong-soft); color: var(--actionable);
      border-color: color-mix(in srgb, var(--actionable) 25%, transparent); font-weight: 700; }
    .chip.monitoring { background: var(--moderate-soft); color: var(--monitoring);
      border-color: color-mix(in srgb, var(--monitoring) 25%, transparent); font-weight: 500; }
    .chip.background { background: var(--low-soft); color: var(--background);
      border-color: color-mix(in srgb, var(--background) 20%, transparent);
      font-weight: 400; font-style: italic; opacity: .85; }

    .flag-borderline { background: var(--borderline-soft); color: var(--borderline);
      font-size: .68rem; font-weight: 700; letter-spacing: .02em; padding: .15rem .5rem;
      border-radius: .35rem; border: 1px solid color-mix(in srgb, var(--borderline) 30%, transparent);
      text-transform: uppercase; }

    h3.title { margin: .55rem 0 .15rem; font-size: 1.02rem; line-height: 1.35; }
    .citation { font-weight: 600; font-size: .82rem; color: var(--fg); }
    .doi { font-size: .78rem; color: var(--muted); }
    .doi a { text-decoration: none; }

    .takeaway { background: var(--accent-soft); border-left: 3px solid var(--accent);
      padding: .5rem .7rem; border-radius: .35rem; margin: .65rem 0;
      font-size: .88rem; font-weight: 600; }
    .takeaway .label { display: block; font-size: .65rem; text-transform: uppercase;
      letter-spacing: .06em; color: var(--accent); margin-bottom: .15rem; font-weight: 700; }

    .why { font-size: .82rem; color: var(--muted); margin: .35rem 0 .5rem; }
    .why .label { font-weight: 700; color: var(--fg); }

    .points { margin: .55rem 0 0; padding-left: 1.1rem; }
    .points li { font-size: .85rem; margin-bottom: .3rem; }
    .points li .cat { font-size: .68rem; margin-left: .35rem; }

    .terms-pills { display: flex; flex-wrap: wrap; gap: .3rem; margin-top: .55rem; }
    .pill { font-size: .68rem; padding: .1rem .45rem; border-radius: 999px;
      background: var(--bg); border: 1px solid var(--border); color: var(--muted); }
    .pill.other { font-style: italic; }

    details.abstract { margin-top: .55rem; }
    details.abstract > summary { cursor: pointer; font-size: .8rem; color: var(--accent);
      list-style: none; user-select: none; }
    details.abstract > summary::-webkit-details-marker { display: none; }
    details.abstract > summary::before { content: "▸ "; font-size: .7rem; }
    details.abstract[open] > summary::before { content: "▾ "; }
    details.abstract > .abstract-body { font-size: .86rem; line-height: 1.55;
      color: var(--fg); margin-top: .4rem; padding-top: .4rem; border-top: 1px dashed var(--border); }

    .card-actions { margin-top: .55rem; display: flex; gap: .4rem; flex-wrap: wrap; }
    .btn-copy { font: inherit; font-size: .72rem; color: var(--muted); background: var(--surface);
      border: 1px solid var(--border); border-radius: .35rem; padding: .2rem .5rem; cursor: pointer;
      transition: color .12s, border-color .12s; }
    .btn-copy:hover { color: var(--accent); border-color: var(--accent); }
    .btn-copy.copied { color: var(--strong); border-color: var(--strong); }

    .empty { color: var(--muted); font-style: italic; padding: 2rem 0; }

    /* Print */
    @media print {
      body { background: #fff; }
      .layout { max-width: none; padding: 0; }
      .filters, .card-actions { display: none; }
      article.card { break-inside: avoid; box-shadow: none; border-left-width: 3px; }
      article.card[hidden] { display: block !important; }
      .empty-filter { display: none !important; }
      details.abstract > .abstract-body { display: block !important; }
      details.abstract > summary { display: none; }
      a { color: var(--fg); text-decoration: underline; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <div class="topbar">
      <a class="back" href="../index.html">&larr; all areas</a>
      <h1>{{ area.name }}</h1>
      <div class="meta">
        {{ articles|length }} retained article{{ '' if articles|length == 1 else 's' }} &middot;
        threshold {{ threshold }}/100 &middot; borderline within &plusmn;{{ borderline_band }} &middot;
        generated {{ generated_at }}
      </div>
      {% if articles %}
      <div class="summary">
        {% set ns = namespace(strong=0, mod=0, low=0, borderline=0) %}
        {% for art in articles if art.screening %}
          {% if art.screening.score >= 80 %}{% set ns.strong = ns.strong + 1 %}
          {% elif art.screening.score >= 60 %}{% set ns.mod = ns.mod + 1 %}
          {% else %}{% set ns.low = ns.low + 1 %}{% endif %}
          {% if art.screening.score >= threshold - borderline_band and art.screening.score < threshold + borderline_band %}
          {% set ns.borderline = ns.borderline + 1 %}{% endif %}
        {% endfor %}
        <span><b>{{ ns.strong }}</b> strong (80&ndash;100)</span>
        <span><b>{{ ns.mod }}</b> moderate (60&ndash;79)</span>
        {% if ns.low %}<span><b>{{ ns.low }}</b> low (&lt;60)</span>{% endif %}
        {% if ns.borderline %}<span><b>{{ ns.borderline }}</b> borderline</span>{% endif %}
        <span><b>{{ terms|length }}</b> search term{{ '' if terms|length == 1 else 's' }}</span>
      </div>
      {% endif %}
    </div>

    {% if articles %}
    <div class="filters" role="group" aria-label="Filter by search term">
      <button class="filter-btn" type="button" data-term="all" aria-pressed="true">
        All <span class="count">{{ articles|length }}</span>
      </button>
      {% for term in terms %}
      <button class="filter-btn" type="button" data-term="{{ term.name }}" aria-pressed="false">
        {{ term.name }} <span class="count">{{ term.count }}</span>
      </button>
      {% endfor %}
    </div>

    <p class="empty-filter" id="empty-filter">No articles match this term.</p>

    <main>
      {% for art in articles %}
        {% set scr = art.screening %}
        {% set band = 'band-strong' if (scr and scr.score >= 80) else ('band-moderate' if (scr and scr.score >= 60) else ('band-low' if scr else '')) %}
        {% set is_borderline = scr and (scr.score >= threshold - borderline_band) and (scr.score < threshold + borderline_band) %}
        {% set takeaway = (scr.key_takeaway if (scr and scr.key_takeaway) else (art.action_points[0].text if art.action_points else None)) %}
        {% set terms_attr = art.matched_terms|join(' ') if art.matched_terms else 'other' %}
      <article class="card {{ band }}{{ ' is-borderline' if is_borderline else '' }}" data-terms="{{ terms_attr }}">
        <div class="card-top">
          <div class="badges">
            {% if scr %}
              <span class="score {{ band }}">{{ scr.score }}</span>
              <span class="chip {{ scr.category|replace(' ', '-') }}">{{ scr.category }}</span>
              {% if is_borderline %}<span class="flag-borderline" title="within ±{{ borderline_band }} of the {{ threshold }} threshold">borderline</span>{% endif %}
            {% endif %}
          </div>
          <div class="doi">
            {% if art.doi %}DOI: <a href="https://doi.org/{{ art.doi }}">{{ art.doi }}</a>{% endif %}
          </div>
        </div>

        <h3 class="title">{{ art.title or "(no title)" }}</h3>
        <div class="citation">{{ art.citation }}</div>

        {% if takeaway %}
        <div class="takeaway">
          <span class="label">Key takeaway</span>
          {{ takeaway }}
        </div>
        {% endif %}

        {% if scr %}
        <p class="why"><span class="label">Why this matters:</span> {{ scr.rationale }}</p>
        {% endif %}

        {% if art.action_points %}
        <ul class="points">
          {% for ap in art.action_points %}
          <li>{{ ap.text }}<span class="cat">[{{ ap.category }}]</span></li>
          {% endfor %}
        </ul>
        {% endif %}

        {% if art.matched_terms %}
        <div class="terms-pills" aria-label="Matched by">
          {% for t in art.matched_terms %}
          <span class="pill">{{ t }}</span>
          {% endfor %}
        </div>
        {% else %}
        <div class="terms-pills" aria-label="Matched by">
          <span class="pill other">Other</span>
        </div>
        {% endif %}

        {% if art.abstract %}
        <details class="abstract">
          <summary aria-expanded="false">Show abstract</summary>
          <div class="abstract-body">{{ art.abstract }}</div>
        </details>
        {% endif %}

        <div class="card-actions">
          <button class="btn-copy" type="button"
            data-citation="{{ art.citation }}{% if art.doi %} https://doi.org/{{ art.doi }}{% endif %}"
            aria-label="Copy citation">Copy citation</button>
        </div>
      </article>
      {% endfor %}
    </main>
    {% else %}
    <main><p class="empty">No articles retained for this area in the latest run.</p></main>
    {% endif %}
  </div>

  <script>
    (function () {
      var buttons = Array.prototype.slice.call(document.querySelectorAll('.filter-btn'));
      var cards = Array.prototype.slice.call(document.querySelectorAll('article.card[data-terms]'));
      var emptyEl = document.getElementById('empty-filter');

      function applyFilter(term) {
        var matchCount = 0;
        cards.forEach(function (card) {
          var terms = card.getAttribute('data-terms').split(' ');
          var show = (term === 'all') || (terms.indexOf(term) !== -1);
          if (show) { card.removeAttribute('hidden'); matchCount++; }
          else { card.setAttribute('hidden', ''); }
        });
        buttons.forEach(function (btn) {
          btn.setAttribute('aria-pressed', btn.getAttribute('data-term') === term ? 'true' : 'false');
        });
        if (emptyEl) {
          if (matchCount === 0 && term !== 'all') { emptyEl.classList.add('is-visible'); }
          else { emptyEl.classList.remove('is-visible'); }
        }
      }

      function termFromHash() {
        var h = location.hash || '';
        var prefix = '#term-';
        if (h.indexOf(prefix) === 0) return decodeURIComponent(h.slice(prefix.length));
        return 'all';
      }

      function setHash(term) {
        if (term === 'all') {
          history.replaceState(null, '', location.pathname + location.search);
        } else {
          history.replaceState(null, '', '#term-' + encodeURIComponent(term));
        }
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var term = btn.getAttribute('data-term');
          setHash(term);
          applyFilter(term);
        });
      });

      window.addEventListener('hashchange', function () { applyFilter(termFromHash()); });

      // Apply the filter indicated by the URL hash on load (deep-link support).
      var initial = termFromHash();
      var known = buttons.some(function (btn) { return btn.getAttribute('data-term') === initial; });
      applyFilter(known ? initial : 'all');
    })();

    // Copy-citation: copy the data-citation string to the clipboard and give
    // brief visual confirmation. No external dependencies.
    document.querySelectorAll('.btn-copy').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var text = btn.getAttribute('data-citation') || '';
        var done = function () {
          var prev = btn.textContent;
          btn.textContent = 'Copied';
          btn.classList.add('copied');
          setTimeout(function () { btn.textContent = prev; btn.classList.remove('copied'); }, 1400);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(done, function () {});
        } else {
          var ta = document.createElement('textarea');
          ta.value = text; document.body.appendChild(ta); ta.select();
          try { document.execCommand('copy'); done(); } catch (e) {}
          document.body.removeChild(ta);
        }
      });
    });

    // Keep the <details> summary's aria-expanded in sync (for older browsers).
    document.querySelectorAll('details.abstract').forEach(function (d) {
      var sync = function () { d.querySelector('summary').setAttribute('aria-expanded', d.open ? 'true' : 'false'); };
      d.addEventListener('toggle', sync); sync();
    });

    // Before printing, open all collapsed abstracts so print-to-PDF shows them.
    // Restore the previous state afterwards so the on-screen view is unchanged.
    // The filter JS hides cards via [hidden]; print CSS forces them visible.
    (function () {
      var snapshot = [];
      window.addEventListener('beforeprint', function () {
        snapshot = [];
        document.querySelectorAll('details.abstract').forEach(function (d) {
          snapshot.push(d.open);
          d.open = true;
        });
      });
      window.addEventListener('afterprint', function () {
        document.querySelectorAll('details.abstract').forEach(function (d, i) {
          if (typeof snapshot[i] !== 'undefined') d.open = snapshot[i];
        });
      });
    })();
  </script>
</body>
</html>
