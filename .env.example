# ─── IMAP shared inbox (Scopus alert emails) ───────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=alerts@example.org
IMAP_PASSWORD=app-specific-password-here
# IMAP folder to move processed alerts into (created if missing)
IMAP_PROCESSED_FOLDER=Processed

# ─── Elsevier Scopus Search API (metadata enrichment) ──────────────────────
SCOPUS_API_KEY=your-elsevier-api-key
SCOPUS_INST_TOKEN=

# ─── LLM provider (LiteLLM — provider-agnostic) ────────────────────────────
# Examples:
#   LIT_MODEL=openai/gpt-4o-mini         (needs OPENAI_API_KEY)
#   LIT_MODEL=anthropic/claude-3-5-sonnet (needs ANTHROPIC_API_KEY)
#   LIT_MODEL=ollama/llama3               (needs OLLAMA host running)
LIT_MODEL=openai/gpt-4o-mini
LIT_API_KEY=
LIT_API_BASE=

# ─── Polite pool identification for OpenAlex / Crossref ────────────────────
CONTACT_EMAIL=you@example.org

# ─── Paths (defaults are fine for most setups) ─────────────────────────────
DATA_DIR=./data
AREAS_CONFIG=./config/areas.yaml
ORG_CONTEXT=./config/organisation_context.md
